/* ── Parse stack ─────────────────────────────────────────────────── */
#define MAXSTACK 1024
#define MAXSYM     64
static char pstk[MAXSTACK][MAXSYM];
static int  ptop=-1;
static void ps_push(const char *s){ if(ptop<MAXSTACK-1) strncpy(pstk[++ptop],s,MAXSYM-1); }
static void ps_pop(char *o)       { if(ptop>=0) strcpy(o,pstk[ptop--]); else o[0]='\0'; }
static void ps_reset(void)        { ptop=-1; }
static void ps_str(char *buf,int sz){
    buf[0]='\0';
    for(int i=0;i<=ptop;i++){
        if(i&&(int)strlen(buf)<sz-2) strcat(buf," ");
        strncat(buf,pstk[i],(size_t)(sz-(int)strlen(buf)-1));
    }
}

static int find_t(const char *x){
    for(int i=0;i<NTER;i++) if(!strcmp(TERM_NAME[i],x)) return i;
    return -1;
}
static int find_nt(const char *x){
    for(int i=0;i<NNT;i++) if(!strcmp(NT_NAME[i],x)) return i;
    return -1;
}

/* ═══════════════════════════════════════════════════════════════════
 *  SECTION 3 — REPORT ENGINE  (enhanced colour & layout)
 * ═══════════════════════════════════════════════════════════════════ */

#define W_STACK 52
#define W_LINE   4
#define W_LEX   22
#define W_TOK   12
#define W_ACT   60

static void hline(FILE *f){
    fprintf(f,"+"); for(int i=0;i<W_STACK+2;i++) fprintf(f,"─");
    fprintf(f,"+"); for(int i=0;i<W_LINE+2; i++) fprintf(f,"─");
    fprintf(f,"+"); for(int i=0;i<W_LEX+2;  i++) fprintf(f,"─");
    fprintf(f,"+"); for(int i=0;i<W_TOK+2;  i++) fprintf(f,"─");
    fprintf(f,"+"); for(int i=0;i<W_ACT+2;  i++) fprintf(f,"─");
    fprintf(f,"+\n");
}

static void hline_plain(FILE *f){
    fprintf(f,"+"); for(int i=0;i<W_STACK+2;i++) fprintf(f,"-");
    fprintf(f,"+"); for(int i=0;i<W_LINE+2; i++) fprintf(f,"-");
    fprintf(f,"+"); for(int i=0;i<W_LEX+2;  i++) fprintf(f,"-");
    fprintf(f,"+"); for(int i=0;i<W_TOK+2;  i++) fprintf(f,"-");
    fprintf(f,"+"); for(int i=0;i<W_ACT+2;  i++) fprintf(f,"-");
    fprintf(f,"+\n");
}

/* truncate a string to fit width w, using ellipsis */
static void fit(char *dst, const char *src, int w){
    int n=(int)strlen(src);
    if(n<=w){ strncpy(dst,src,(size_t)w); dst[w]='\0'; return; }
    strncpy(dst,src,(size_t)(w-3)); dst[w-3]='.'; dst[w-2]='.'; dst[w-1]='.'; dst[w]='\0';
}

static void prow(FILE *f,
                 const char *stack, const char *lnum,
                 const char *lex,   const char *tok, const char *act,
                 const char *cs,    const char *cl,
                 const char *cx,    const char *ct,  const char *ca, int colour)
{
    char s2[W_STACK+1], l2[W_LINE+1], x2[W_LEX+1], t2[W_TOK+1], a2[W_ACT+1];
    fit(s2,stack,W_STACK); fit(l2,lnum,W_LINE);
    fit(x2,lex,W_LEX);     fit(t2,tok,W_TOK);     fit(a2,act,W_ACT);
    if(colour)
        fprintf(f,"│ %s%-*s%s │ %s%-*s%s │ %s%-*s%s │ %s%-*s%s │ %s%-*s%s │\n",
            cs,W_STACK,s2,RST, cl,W_LINE,l2,RST,
            cx,W_LEX,x2,RST,  ct,W_TOK,t2,RST,
            ca,W_ACT,a2,RST);
    else
        fprintf(f,"| %-*s | %-*s | %-*s | %-*s | %-*s |\n",
            W_STACK,s2, W_LINE,l2, W_LEX,x2, W_TOK,t2, W_ACT,a2);
}

/* ── Box-drawing helpers ─────────────────────────────────────────── */
static void top_box(FILE *f, const char *title, int colour){
    int tw = W_STACK+W_LINE+W_LEX+W_TOK+W_ACT + 14;
    if(colour) fprintf(f,"%s",CYN);
    fprintf(f,"╔"); for(int i=0;i<tw-2;i++) fprintf(f,"═"); fprintf(f,"╗\n");
    int tl=(int)strlen(title);
    int pad=(tw-2-tl)/2;
    fprintf(f,"║"); for(int i=0;i<pad;i++) fprintf(f," ");
    if(colour) fprintf(f,"%s%s%s",BOLD,title,CYN);
    else        fprintf(f,"%s",title);
    for(int i=pad+tl;i<tw-2;i++) fprintf(f," ");
    fprintf(f,"║\n");
    fprintf(f,"╚"); for(int i=0;i<tw-2;i++) fprintf(f,"═"); fprintf(f,"╝\n");
    if(colour) fprintf(f,"%s",RST);
}

static void report_lexer(FILE *f,int colour){
    fprintf(f,"\n");
    top_box(f,"  ◈  DFA LEXER  —  TOKENIZED OUTPUT  ◈  ",colour);
    fprintf(f,"\n");
    if(colour) fprintf(f,"%s",DIM);
    fprintf(f,"  DFA  : %d states  ×  %d input classes\n",NUM_STATES,NC);
    fprintf(f,"  Logic: next_state[state][class]  +  accepting_tokens[state]\n");
    fprintf(f,"  New  : MINUS('-'), LESSEQ('<=') tokens added\n\n");
    if(colour) fprintf(f,"%s",RST);

    /* column headers */
    int lw=6, tw=14, xw=30;
    if(colour) fprintf(f,"%s",BOLD);
    fprintf(f,"  %-*s  %-*s  %s\n", lw,"LINE", tw,"TOKEN TYPE", "LEXEME");
    if(colour) fprintf(f,"%s",RST);
    if(colour) fprintf(f,"%s",DIM);
    fprintf(f,"  %-*s  %-*s  %s\n", lw,"──────", tw,"──────────────", "──────────────────────────────");
    if(colour) fprintf(f,"%s",RST);

    for(int i=0;i<ntok;i++){
        const char *col="";
        if(colour){
            if(!strcmp(tokens[i].type,"UNKNOWN"))   col=RED;
            else if(!strcmp(tokens[i].type,"COMMENT")) col=DIM;
            else if(!strcmp(tokens[i].type,"INCLUDE")) col=MAG;
            else if(!strcmp(tokens[i].type,"NUM"))     col=BLU;
            else if(!strcmp(tokens[i].type,"VAR"))     col=WHT;
            else if(!strcmp(tokens[i].type,"FUNC"))    col=CYN;
            else if(!strcmp(tokens[i].type,"LABEL"))   col=YLW;
            else if(!strcmp(tokens[i].type,"INT")||!strcmp(tokens[i].type,"DEC")
                  ||!strcmp(tokens[i].type,"RETURN")||!strcmp(tokens[i].type,"WHILE")
                  ||!strcmp(tokens[i].type,"BREAK")||!strcmp(tokens[i].type,"BUILTIN")
                  ||!strcmp(tokens[i].type,"MAINFN"))  col=MAG;
            else                                       col=GRN;
        }
        fprintf(f,"  %s%-*d%s  %s%-*s%s  %s\n",
            colour?YLW:"", lw, tokens[i].line, colour?RST:"",
            col, tw, tokens[i].type, colour?RST:"",
            tokens[i].lex);
    }

    /* frequency table */
    const char *ut[64]; int uf[64]; int nu=0;
    for(int i=0;i<ntok;i++){
        int found=0;
        for(int j=0;j<nu;j++) if(ut[j]==tokens[i].type){uf[j]++;found=1;break;}
        if(!found&&nu<64){ut[nu]=tokens[i].type;uf[nu]=1;nu++;}
    }
    fprintf(f,"\n");
    if(colour) fprintf(f,"%s",DIM);
    fprintf(f,"  ─────────────────────────────────────────────────\n");
    if(colour) fprintf(f,"%s",RST);
    if(colour) fprintf(f,"%s",BOLD);
    fprintf(f,"  Total: %d tokens\n\n  Frequency:\n",ntok);
    if(colour) fprintf(f,"%s",RST);
    for(int j=0;j<nu;j++){
        int bar=uf[j]; if(bar>40) bar=40;
        if(colour) fprintf(f,"  %s%-14s%s : %s%-3d%s ",MAG,ut[j],RST,YLW,uf[j],RST);
        else        fprintf(f,"  %-14s : %-3d ",ut[j],uf[j]);
        if(colour) fprintf(f,"%s",GRN);
        for(int k=0;k<bar;k++) fprintf(f,"█");
        if(colour) fprintf(f,"%s",RST);
        fprintf(f,"\n");
    }
}

/* ── PARSER ─────────────────────────────────────────────────────── */
static void parse_program(FILE *f, int colour){
    fprintf(f,"\n\n");
    top_box(f,"  ◈  LL(1) PARSER  —  FULL PARSE TRACE  ◈  ",colour);
    fprintf(f,"\n");
    if(colour) fprintf(f,"%s",DIM);
    fprintf(f,
        "  Grammar extensions (vs original):\n"
        "    • MINUS('-') token — Expr now supports subtraction\n"
        "    • LESSEQ('<=') token — WhileStmt accepts '<' or '<='\n"
        "    • Expr -> VAR|NUM  [PLUS|MINUS]  Expr  (binary ops unified)\n"
        "    • FuncDecl param is a _VAR (underscore-prefixed identifier)\n"
        "    • Parse table: %d non-terminals × %d terminals\n\n",NNT,NTER);
    if(colour) fprintf(f,"%s",RST);

    #define MAX_PI 2048
    int pidx[MAX_PI]; int np=0;
    for(int i=0;i<ntok&&np<MAX_PI-1;i++)
        if(strcmp(tokens[i].type,"UNKNOWN")!=0)
            pidx[np++]=i;

    /* header row */
    if(colour) hline(f); else hline_plain(f);
    prow(f,"STACK TOP     ","LINE","LEXEME","TOKEN",
         "ACTION / PRODUCTION",BOLD,BOLD,BOLD,BOLD,BOLD,colour);
    if(colour) hline(f); else hline_plain(f);

    ps_reset();
    ps_push("$");
    ps_push("Program");

    int ip=0, accepted=0, error=0;

    while(ptop>=0){
        char X[MAXSYM]; ps_pop(X);

        const char *a_type, *a_lex, *a_line_s;
        char linebuf[8];
        if(ip<np){
            int ti=pidx[ip];
            a_type=tokens[ti].type; a_lex=tokens[ti].lex;
            snprintf(linebuf,sizeof(linebuf),"%d",tokens[ti].line);
            a_line_s=linebuf;
        } else {
            a_type="$"; a_lex="$"; a_line_s="-";
        }

        /* Show only the top of stack (X) instead of entire stack */
        char disp[900];
        snprintf(disp,sizeof(disp),"%s",X);

        int tindex=find_t(X);

        /* ── TERMINAL: match or error ──────────────────────────── */
        if(tindex!=-1){
            if(!strcmp(X,a_type)){
                char act[160];
                if(!strcmp(X,"$")){
                    snprintf(act,sizeof(act),"match $  ──  ACCEPT ✓");
                    prow(f,disp,a_line_s,a_lex,a_type,act,DIM,MAG,MAG,MAG,GRNBG,colour);
                    accepted=1; break;
                }
                snprintf(act,sizeof(act),"match  %-10s  [%s]",X,a_lex);
                prow(f,disp,a_line_s,a_lex,a_type,act,"",CYN,CYN,CYN,GRN,colour);
                ip++;
            } else {
                char act[160];
                snprintf(act,sizeof(act),"✗ expected %-10s  got %s [%s]",X,a_type,a_lex);
                prow(f,disp,a_line_s,a_lex,a_type,act,"",RED,RED,RED,REDBG,colour);
                error=1; break;
            }
            continue;
        }

        /* ── NON-TERMINAL: table lookup ────────────────────────── */
        int ntindex=find_nt(X);
        if(ntindex==-1){
            char act[120]; snprintf(act,sizeof(act),"✗ unknown symbol '%s'",X);
            prow(f,disp,a_line_s,a_lex,a_type,act,"",RED,RED,RED,REDBG,colour);
            error=1; break;
        }

        int prod=0;

        /* ── FuncDeclList: 1-token look-ahead disambiguation ──── */
        if(ntindex==NT_FUNCDECLLIST){
            int aindex=find_t(a_type);
            if(aindex==T_INT||aindex==T_DEC){
                const char *next_type="$";
                if(ip+1<np) next_type=tokens[pidx[ip+1]].type;
                prod=(!strcmp(next_type,"MAINFN"))?6:5;
            } else {
                int ai=find_t(a_type); if(ai<0) ai=T_DOLLAR;
                prod=parse_table[ntindex][ai];
            }
        }

        /* ── WhileStmt: accept LESS or LESSEQ ────────────────── */
        else if(ntindex==NT_WHILESTMT){
            /* Rule 23 has LESS in it; we'll push LESS or LESSEQ dynamically */
            prod=23; /* always rule 23 — we patch the LESS slot below */
        }

        /* ── Expr: 2-token peek resolves operator ─────────────── */
        else if(ntindex==NT_EXPR){
            int is_var =!strcmp(a_type,"VAR");
            int is_num =!strcmp(a_type,"NUM");
            int is_func=!strcmp(a_type,"FUNC");

            if(is_var||is_num){
                const char *next_type="$";
                if(ip+1<np) next_type=tokens[pidx[ip+1]].type;
                int has_plus =!strcmp(next_type,"PLUS");
                int has_minus=!strcmp(next_type,"MINUS");
                if(is_var){
                    if(has_plus)  prod=33;
                    else if(has_minus) prod=37;
                    else          prod=34;
                } else {
                    if(has_plus)  prod=35;
                    else if(has_minus) prod=39;
                    else          prod=36;
                }
            } else if(is_func){
                /* Expr -> FUNC LPAREN ArgOpt RPAREN  (inline, no table entry) */
                char act[120]; snprintf(act,sizeof(act),"Expr -> FUNC LPAREN ArgOpt RPAREN");
                prow(f,disp,a_line_s,a_lex,a_type,act,"",CYN,CYN,MAG,YLW,colour);
                ps_push("RPAREN");
                ps_push("ArgOpt");
                ps_push("LPAREN");
                ps_push("FUNC");
                continue;
            } else {
                char act[160];
                snprintf(act,sizeof(act),"✗ Expr expects VAR/NUM/FUNC, got %s",a_type);
                prow(f,disp,a_line_s,a_lex,a_type,act,"",RED,RED,RED,REDBG,colour);
                error=1; break;
            }
        }

        else {
            int aindex=find_t(a_type);
            if(aindex<0) aindex=T_DOLLAR;
            prod=parse_table[ntindex][aindex];
        }

        if(prod==0){
            char act[160];
            snprintf(act,sizeof(act),"✗ no rule for ( %s , %s )",X,a_type);
            prow(f,disp,a_line_s,a_lex,a_type,act,"",RED,RED,RED,REDBG,colour);
            error=1; break;
        }

        const char *ac=(strlen(rule_rhs[prod-1])==0)?DIM:YLW;
        prow(f,disp,a_line_s,a_lex,a_type,rule_label[prod-1],"",CYN,CYN,MAG,ac,colour);

        if(strlen(rule_rhs[prod-1])>0){
            /*
             *  Special case — WhileStmt rule 23:
             *  The grammar says LESS but if current token is LESSEQ we push LESSEQ instead.
             *  This keeps everything else identical.
             */
            char rhs[300]; strncpy(rhs,rule_rhs[prod-1],sizeof(rhs)-1);
            if(prod==23 && ip<np && !strcmp(tokens[pidx[ip]].type,"WHILE")){
                /* look ahead to find the comparison token */
                /* scan forward through WHILE LPAREN TypeKw VAR to find LESS/LESSEQ */
                /* We'll substitute at push time by checking actual token stream */
            }

            char tmp[300]; strncpy(tmp,rule_rhs[prod-1],sizeof(tmp)-1);
            char *tok2=strtok(tmp," ");
            char syms[64][MAXSYM]; int k=0;
            while(tok2&&k<64){
                strncpy(syms[k],tok2,MAXSYM-1);
                /*
                 *  Patch: if this symbol is "LESS" and the actual upcoming comparison
                 *  token in the stream is "LESSEQ", push "LESSEQ" instead.
                 *  We search forward in pidx for the LESS/LESSEQ token after the WHILE/LPAREN/TypeKw/VAR.
                 */
                if(!strcmp(syms[k],"LESS")){
                    /* find the comparison token: it's pidx[ip+4] for rule 23
                       (WHILE=ip, LPAREN=ip+1, INT/DEC=ip+2, VAR=ip+3, cmp=ip+4) */
                    int cmp_pos=ip+4;
                    if(cmp_pos<np && !strcmp(tokens[pidx[cmp_pos]].type,"LESSEQ"))
                        strncpy(syms[k],"LESSEQ",MAXSYM-1);
                }
                if(!strcmp(syms[k],"GREATER")){
                    int cmp_pos=ip+4;
                    if(cmp_pos<np){
                        if(!strcmp(tokens[pidx[cmp_pos]].type,"GREATEREQ"))
                            strncpy(syms[k],"GREATEREQ",MAXSYM-1);
                    }
                }
                k++; tok2=strtok(NULL," ");
            }
            for(int i=k-1;i>=0;i--) ps_push(syms[i]);
        }
    }

    if(colour) hline(f); else hline_plain(f);

    /* verdict banner */
    int total_w=W_STACK+W_LINE+W_LEX+W_TOK+W_ACT+14;
    const char *verdict=accepted&&!error?"ACCEPTED ✓":"REJECTED ✗";
    const char *detail =accepted&&!error?"program is syntactically valid":"syntax error detected";
    char footer[220]; snprintf(footer,sizeof(footer),"  RESULT: %s  —  %s",verdict,detail);
    int pad=total_w-4-(int)strlen(footer); if(pad<0) pad=0;
    const char *bc=accepted&&!error?GRNBG:REDBG;
    if(colour) fprintf(f,"│%s%-*s%s│\n",bc,total_w-2,footer,RST);
    else        fprintf(f,"|%-*s|\n",total_w-2,footer);
    if(colour) hline(f); else hline_plain(f);
}

static void full_report(FILE *f, int colour){
    report_lexer(f,colour);
    parse_program(f,colour);
}

int main(void){
    FILE *fin=fopen("input.cbl","r");
    char src[16384]={0};
    if(fin){ int n=(int)fread(src,1,sizeof(src)-1,fin); fclose(fin); src[n]='\0'; }
    else { fprintf(stderr,RED"Cannot open input.cbl\n"RST); return 1; }

    scan(src);
    full_report(stdout,1);

    FILE *fout=fopen("tokenized.txt","w");
    if(fout){ full_report(fout,0); fclose(fout); }
    printf("\n%s  [Output saved → tokenized.txt]  %s\n",GRNBG,RST);
    return 0;
}
