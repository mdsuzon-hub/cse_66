};

typedef struct { const char *type; char lex[256]; int line; } Token;
static Token tokens[MAX_TOK];
static int   ntok = 0;

static void add_tok(const char *type, const char *lex, int line){
    if(ntok>=MAX_TOK) return;
    tokens[ntok].type=type;
    strncpy(tokens[ntok].lex,lex,255); tokens[ntok].lex[255]='\0';
    tokens[ntok].line=line; ntok++;
}

static void scan(const char *src){
    int i=0, len=(int)strlen(src), line=1;
    while(i<len){
        if(src[i]=='\n'){line++;i++;continue;}
        if(src[i]==' '||src[i]=='\t'||src[i]=='\r'){i++;continue;}
        int state=0,start=i,las=-1,lap=-1;
        
        // Try to find a valid token first
        while(i<len){
            unsigned char c=(unsigned char)src[i];
            if(c=='\n') break;
            int cl=get_class(c);
            int ns=next_state[state][cl];
            if(ns==DEAD) break;
            state=ns; i++;
            if(accepting_tokens[state]){las=state;lap=i;}
        }
        
        // If we found a valid token before hitting DEAD
        if(lap!=-1){
            i=lap;
            int tlen=i-start; 
            char lex[256]; 
            strncpy(lex,src+start,tlen); 
            lex[tlen]='\0';
            add_tok(accepting_tokens[las],lex,line);
        } 
        // No valid token found - collect entire invalid sequence
        else {
            // Find the end of the invalid token (until whitespace or newline)
            int invalid_end = start;
            while(invalid_end < len && 
                  src[invalid_end] != ' ' && 
                  src[invalid_end] != '\t' && 
                  src[invalid_end] != '\n' &&
                  src[invalid_end] != '\r') {
                invalid_end++;
            }
            
            // Collect the entire invalid sequence as one token
            int tlen = invalid_end - start;
            char lex[256];
            strncpy(lex, src + start, tlen);
            lex[tlen] = '\0';
            add_tok("UNKNOWN", lex, line);
            i = invalid_end;
        }
    }
}

